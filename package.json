{
  "name": "forgesworn-demos",
  "version": "0.0.0",
  "private": true,
  "description": "Interactive demos for the ForgeSworn crypto toolkit",
  "type": "module",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r --filter './apps/*' build",
    "dev": "pnpm -r --parallel --filter './apps/*' dev",
    "test": "pnpm -r --filter './apps/*' test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.58.2"
  }
}
